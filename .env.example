# ==============================================================================
# FreshCart Environment Variables Configuration Example Template
# ==============================================================================

# Node Environment ('development' or 'production')
NODE_ENV=development

# Server Port
PORT=5000

# MongoDB Database URI (Atlas connection string or local MongoDB instance)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/freshcart?retryWrites=true&w=majority

# JWT Secrets for Cookie & Session Token Issue
JWT_SECRET=super_secret_jwt_sign_key_for_session_token_signing
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=7

# Frontend Client Origin URL (for CORS allowance)
FRONTEND_URL=http://localhost:5173

# ==============================================================================
# THIRD-PARTY INTEGRATIONS KEYS
# ==============================================================================

# SMTP Nodemailer Credentials (for password reset links)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-gmail-address@gmail.com
SMTP_PASSWORD=your-app-specific-gmail-password
FROM_EMAIL=FreshCart Service <noreply@freshcart.com>
FROM_NAME=FreshCart

# Cloudinary CDN Credentials (for product image uploads storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay Checkout Gateway Keys
RAZORPAY_KEY_ID=rzp_test_placeholder_key_id
RAZORPAY_KEY_SECRET=rzp_test_placeholder_key_secret

# Stripe Checkout Gateway Keys
STRIPE_SECRET_KEY=sk_test_placeholder_secret_key
STRIPE_WEBHOOK_SECRET=whsec_placeholder_webhook_signing_secret
